{
  "name": "playwrightautomation",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "cross-env ENV=dev npx playwright test ./tests/testpage.spec.js --reporter=html",
    "test:headed": "cross-env ENV=qa npx playwright test --headed",
    "test:debug": "cross-env ENV=qa npx playwright test --debug",
    "test:report": "npx playwright show-report",
    "allure:generate": "allure generate ./allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.30",
    "allure-commandline": "^2.37.0",
    "allure-playwright": "^3.6.0"
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1"
  }
}